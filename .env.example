# sd2video real-environment configuration template.
#
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
#
# `.env` is git-ignored. DO NOT commit it or paste its contents anywhere
# (logs, issue comments, screenshots, frontend bundles).

# ---------------------------------------------------------------------------
# Required for any live call to Volcengine Ark
# ---------------------------------------------------------------------------

# Volcengine Ark API key. Read by ArkConfig.from_env() at backend startup.
# Never exposed to the browser, the frontend bundle, or task payloads.
ARK_API_KEY=

# ---------------------------------------------------------------------------
# Optional Ark overrides (the SDK has safe defaults; leave unset unless needed)
# ---------------------------------------------------------------------------

# Defaults to https://ark.cn-beijing.volces.com
# ARK_BASE_URL=

# Defaults to doubao-seedance-2-0-fast-260128
# ARK_DEFAULT_MODEL_ID=

# Defaults to 30.0 seconds
# ARK_TIMEOUT_SECONDS=

# ---------------------------------------------------------------------------
# Smoke test gates (all OFF by default — CI and `unittest discover` stay mocked)
# ---------------------------------------------------------------------------

# Set to 1 to enable the live smoke test class. Without this flag the live
# tests are skipped, even if ARK_API_KEY is set.
# ARK_RUN_SMOKE_TESTS=

# Set to 1 to additionally allow the live create-task test, which submits a
# real (billable) generation. Pair with ARK_SMOKE_MODEL_ID and keep duration /
# resolution at the cheapest acceptable values.
# ARK_SMOKE_CREATE_TASK=

# Model ID used by the live create-task smoke test. Pick a Seedance-2 model
# you are entitled to call, e.g. doubao-seedance-2-0-fast-260128.
# ARK_SMOKE_MODEL_ID=

# Cost-shaping overrides for the live create-task smoke test. Defaults match
# the cheapest path: 480p, 16:9, 4-second clip.
# ARK_SMOKE_PROMPT="A single red ball rolling slowly across a plain white floor."
# ARK_SMOKE_RATIO=16:9
# ARK_SMOKE_RESOLUTION=480p
# ARK_SMOKE_DURATION=4
